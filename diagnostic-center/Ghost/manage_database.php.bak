<?php
require_once 'includes/header.php';

$feedback = '';
if (isset($_POST['run_sql'])) {
    $sql = $_POST['sql_query'];
    if (trim($sql) !== '') {
        try {
            if ($conn->multi_query($sql)) {
                do {
                    if ($result = $conn->store_result()) {
                        $feedback .= "<div class='card'><h4>Result Set:</h4><div style='overflow-x:auto;'><table><thead><tr>";
                        $fields = $result->fetch_fields();
                        foreach ($fields as $field) {
                            $feedback .= "<th>{$field->name}</th>";
                        }
                        $feedback .= "</tr></thead><tbody>";
                        while ($row = $result->fetch_assoc()) {
                            $feedback .= "<tr>";
                            foreach ($row as $val) {
                                $feedback .= "<td>" . htmlspecialchars((string)$val) . "</td>";
                            }
                            $feedback .= "</tr>";
                        }
                        $feedback .= "</tbody></table></div></div>";
                        $result->free();
                    }
                } while ($conn->next_result());
                $feedback .= "<div style='color:green'>Query executed successfully.</div>";
            } else {
                $feedback = "<div style='color:red'>Error: " . $conn->error . "</div>";
            }
        } catch (Exception $e) {
            $feedback = "<div style='color:red'>Exception: " . $e->getMessage() . "</div>";
        }
    }
}

// Empty table action (Truncate)
if (isset($_GET['empty_table'])) {
    $tbl = $_GET['empty_table'];
    // Truncate is faster and resets auto_increment
    if ($conn->query("TRUNCATE TABLE `$tbl`")) {
        $feedback .= "<div style='color:green; margin-bottom:1rem; padding:10px; background:#e6fffa; border-left:4px solid #38a169;'>Table <strong>$tbl</strong> has been cleared. (Rows: 0)</div>";
    } else {
        $feedback .= "<div style='color:red; margin-bottom:1rem;'>Error clearing table: " . $conn->error . "</div>";
    }
}

// Drop table action
if (isset($_GET['drop_table'])) { // Dangerous!
    $tbl = $_GET['drop_table'];
    // Validating table name to prevent arbitrary injection beyond SQL
    $conn->query("DROP TABLE IF EXISTS `$tbl`");
    header("Location: manage_database.php");
    exit();
}

// Handle Table Views
if (isset($_GET['view_table'])) {
    $tbl = $conn->real_escape_string($_GET['view_table']);
    if ($result = $conn->query("SELECT * FROM `$tbl` LIMIT 1000")) {
        $feedback .= "<div class='card' style='border-left: 5px solid var(--primary);'>
            <div style='display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;'>
                <h3 style='margin:0;'>Browsing: $tbl <small style='font-size:0.6em; color:gray;'>(Top 1000 rows)</small></h3>
                <a href='manage_database.php' class='btn btn-danger btn-sm'><i class='fas fa-times'></i> Close</a>
            </div>
            <div class='table-responsive'><table><thead><tr>";
        $fields = $result->fetch_fields();
        foreach ($fields as $field) $feedback .= "<th>{$field->name}</th>";
        $feedback .= "</tr></thead><tbody>";
        while ($row = $result->fetch_assoc()) {
            $feedback .= "<tr>";
            foreach ($row as $val) {
                $valStr = (strlen((string)$val) > 100) ? substr((string)$val, 0, 100) . '...' : (string)$val;
                $feedback .= "<td>" . htmlspecialchars($valStr) . "</td>";
            }
            $feedback .= "</tr>";
        }
        $feedback .= "</tbody></table></div></div>";
    }
}

if (isset($_GET['view_structure'])) {
    $tbl = $conn->real_escape_string($_GET['view_structure']);
    if ($result = $conn->query("DESCRIBE `$tbl`")) {
        $feedback .= "<div class='card' style='border-left: 5px solid var(--success);'>
            <div style='display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;'>
                <h3 style='margin:0;'>Structure: $tbl</h3>
                <a href='manage_database.php' class='btn btn-danger btn-sm'><i class='fas fa-times'></i> Close</a>
            </div>
            <div class='table-responsive'><table><thead><tr><th>Field</th><th>Type</th><th>Null</th><th>Key</th><th>Default</th><th>Extra</th></tr></thead><tbody>";
        while ($row = $result->fetch_assoc()) {
            $feedback .= "<tr>";
            foreach ($row as $val) $feedback .= "<td>" . htmlspecialchars((string)$val) . "</td>";
            $feedback .= "</tr>";
        }
        $feedback .= "</tbody></table></div></div>";
    }
}

$tables = [];
$res = $conn->query("SHOW TABLES");
if ($res) {
    while($row = $res->fetch_row()) $tables[] = $row[0];
}
?>

<div class="card">
    <h2>Database Manager</h2>
    <p style="color:var(--text-muted); margin-bottom:1rem;">Direct SQL execution. <strong>Use with caution.</strong></p>
    <form method="POST">
        <textarea name="sql_query" class="form-control" rows="5" placeholder="CREATE TABLE... / SELECT * FROM..." style="font-family:'Fira Code', monospace; font-size: 0.9em; tab-size:4;"></textarea>
        <button type="submit" name="run_sql" class="btn btn-primary" style="margin-top:1rem;"><i class="fas fa-play"></i> Run SQL</button>
    </form>
    <br>
    <?php echo $feedback; ?>
</div>

<div class="card">
    <h3>Existing Tables</h3>
    <div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>Table Name</th>
                <th>Rows</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach($tables as $table): 
                $count = $conn->query("SELECT count(*) FROM `$table`")->fetch_row()[0];
            ?>
            <tr>
                <td style="font-family:'Mb'; font-weight:600;">
                    <a href="manage_database.php?view_table=<?php echo $table; ?>" style="color:var(--primary); text-decoration:none; display:flex; align-items:center; gap:0.5rem;">
                        <i class="fas fa-table" style="color:var(--text-muted); font-size:0.8em;"></i> 
                        <?php echo $table; ?>
                    </a>
                </td>
                <td><span class="badge badge-inactive"><?php echo $count; ?> rows</span></td>
                <td>
                    <a href="manage_database.php?view_table=<?php echo $table; ?>" class="btn btn-primary btn-sm"><i class="fas fa-search"></i> Browse</a>
                    <a href="manage_database.php?view_structure=<?php echo $table; ?>" class="btn btn-success btn-sm"><i class="fas fa-code"></i> Structure</a>
                    <a href="manage_database.php?empty_table=<?php echo $table; ?>" class="btn btn-warning btn-sm" onclick="return confirm('WARNING: You are about to DELETE ALL DATA from <?php echo $table; ?>. This will reset the row count to 0. Are you sure?');"><i class="fas fa-eraser"></i> Clear</a>
                     <a href="manage_database.php?drop_table=<?php echo $table; ?>" class="btn btn-danger btn-sm" style="margin-left: 10px;" onclick="return confirm('EXTREMELY DANGEROUS! Drop table <?php echo $table; ?>? This cannot be undone.');"><i class="fas fa-trash-alt"></i> Drop</a>
                </td>
            </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
    </div>
</div>

<?php require_once 'includes/footer.php'; ?>
