# Protect backup files from direct unauthenticated web access
# Downloads are proxied through the Ghost data_backup.php page

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Allow access to PHP files (they have their own auth)
    RewriteCond %{REQUEST_FILENAME} !\.php$
    
    # Allow access to the JSON index
    RewriteCond %{REQUEST_FILENAME} !backup_index\.json$
    
    # Block direct access to .sql files from web
    RewriteRule \.sql$ - [F,L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(json|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
