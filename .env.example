# ============================================================
# Diagnostic Center - Environment Configuration
# ============================================================
# Copy this file to .env and edit the values below.
# Run: copy .env.example .env  (Windows)
#      cp .env.example .env    (Linux/Mac)
# ============================================================

# ---- Application Ports ----
APP_PORT=8081
SSL_PORT=8443
PMA_PORT=8082
DB_PORT=3301

# Bind DB/phpMyAdmin host exposure to local interface by default
# Use 0.0.0.0 only if you intentionally need remote access.
DB_BIND_IP=127.0.0.1
PMA_BIND_IP=127.0.0.1

# ---- Database Settings ----
DB_HOST=db
DB_USER=root
DB_PASS=root_password
DB_NAME=diagnostic_center_db

# Extra user (created alongside root)
DB_EXTRA_USER=diagnostic_user
DB_EXTRA_PASS=diagnostic_pass

# ---- Apache Settings ----
# Set this to your public IP or domain name
# Examples:
#   localhost          (for local development)
#   192.168.1.100      (for local network access)
#   your-domain.com    (for production with domain)
#   203.0.113.50       (for public IP access)
APACHE_SERVER_NAME=localhost

# ---- SSL / HTTPS Settings ----
# Set to "true" to enable HTTPS
# Place your SSL certificate files in docker/ssl/:
#   - docker/ssl/certificate.crt
#   - docker/ssl/private.key
#   - docker/ssl/ca_bundle.crt (optional, for CA chain)
ENABLE_SSL=false

# ---- Public IP Configuration ----
# Set your public IP (leave empty for auto-detection)
PUBLIC_IP=
# Set your local/private IP (leave empty for auto-detection)
LOCAL_IP=
# Enable dual IP binding (listens on both local + public IPs)
DUAL_IP_BIND=true
# How often (seconds) to check if public IP changed
IP_CHECK_INTERVAL=300

# ---- SQL Tunnel Intrusion Guard ----
# true  = block startup when SQL tunnel links/files are tampered
# false = disable startup blocking (not recommended)
INIT_BUNDLE_GUARD=true
