# ============================================================
# Docker Ignore - Diagnostic Center
# ============================================================
# Files/folders excluded from the Docker build context.
# This makes builds faster and images smaller.
# ============================================================

# Docker files themselves
docker-compose.yml
docker-compose.override.yml
.env
.env.example
diagnostic_center_db_.sql
backup-db.bat
backup-db.sh
setup-ssl.bat
setup-ssl.sh
backups/

# Git
.git
.gitignore
.gitattributes

# Documentation
*.md
LICENSE

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
.DS_Store
desktop.ini

# Logs (will be generated fresh in container)
uploads/mail.log
uploads/whatsapp.log

# Development
node_modules/

# SSL certs are mounted as volume, not baked into image
docker/ssl/*.crt
docker/ssl/*.key
docker/ssl/*.pem
